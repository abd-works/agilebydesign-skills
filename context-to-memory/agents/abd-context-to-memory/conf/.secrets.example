# Copy this file to .secrets in this folder (same directory as this example).
# Line format: KEY=value — no spaces around =.
#
# This is the primary config surface: keys are loaded into the process before scripts
# resolve paths (see _config.py). You do NOT need to export variables in the shell for
# normal use — set them here (or in conf/.env).
#
# Load order:
#   conf/.secrets  →  conf/.env  →  <agent>/.env  (orchestrator scripts only)
#   For skill scripts: also <that_skill>/.env  →  cwd/.env
#
# Orchestration + workspace: AGENTS.md at this agent's root.
# Detail: skills/abd-embed-vectors/references/config.md

# Required for embed_and_index.py and search_memory.py (OpenAI embeddings).
OPENAI_API_KEY=sk-replace-me

# Optional — if the API still returns 401, set the project/org the key belongs to:
# OPENAI_PROJECT_ID=proj_xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_ORGANIZATION=org_xxxxxxxxxxxxxxxxxxxxxxxx

# Default topic/corpus folder when you omit --path / --memory (recommended). Uncomment and set:
# CONTENT_MEMORY_ROOT=C:\path\to\your\corpus

# This agent uses local FAISS under <topic>/memory/rag/ — not Pinecone.
# Pinecone / abd-answers hub keys live in abd-answers/conf/, not here.
