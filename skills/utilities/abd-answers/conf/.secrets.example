# Copy to .secrets (same folder). Line format: KEY=value — no spaces around =.
# Used by app-server (chat) and orchestrator. See conf/README.md.
#
# Local memory hub (vector RAG): use conf/answers-memory.env (see answers-memory.env.example), not a SharePoint URL.

OPENAI_API_KEY=sk-replace-me
# Optional: used if the primary key hits quota/rate limits (same name as OPEN_API_KEY_2 in env).
# OPEN_API_KEY_2=sk-replace-me-second
#
# Optional — some orgs / project keys need these (IDs from https://platform.openai.com/settings )
# If you still get 401 after fixing the secret, set the project the key belongs to:
# OPENAI_PROJECT_ID=proj_xxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_ORGANIZATION=org_xxxxxxxxxxxxxxxxxxxxxxxx

# Vector RAG (Pinecone) — same index/namespace as app-server after restart. Values here override
# root `.env` for these keys. Optional PINECONE_NAMESPACE forces one namespace for all memory roots.
# PINECONE_API_KEY=pcsk_...
# PINECONE_INDEX=abd-answers-memory
# PINECONE_NAMESPACE=mr_your-memory-root-id__root
