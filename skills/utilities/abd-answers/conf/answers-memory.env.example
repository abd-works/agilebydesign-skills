# Copy to conf/answers-memory.env (gitignored). Loaded by app-server on startup.
# Use a LOCAL absolute hub path — same hub root as in your content repo’s conf/content_memory_roots.json
# (e.g. abd_content/conf/content_memory_roots.json); abd-answers does not read that file itself.
# Do NOT use https://... SharePoint URLs here; vector RAG reads on-disk index only.
#
# Layout:
#   <hub or repo data/assets>/       — topics (browse in the Source tile); may follow ANSWERS_DEFAULT_HUB_PATH
#   <abd-answers repo>/data/assets/abd-answers-memory-pipeline/  — fixed: markdown/, chunked/, rag/ (not hub-overridden)

# Local clone (dev):
# ANSWERS_DEFAULT_HUB_PATH=C:/dev/abd_content
# OneDrive-synced SharePoint Assets (same folder as diskHubPath on the SharePoint memory root):
ANSWERS_DEFAULT_HUB_PATH=C:/Users/thoma/OneDrive - Agile by Design/Shared Documents/Assets

# Optional: when a memory root's `path` is a SharePoint (or other) URL, the server still needs a disk folder
# for vector RAG. Resolution order: local `path` -> root.diskHubPath (API) -> ANSWERS_RAG_DISK_ROOT -> ANSWERS_DEFAULT_HUB_PATH.
# ANSWERS_RAG_DISK_ROOT=C:/Users/thoma/OneDrive - Agile by Design/Shared Documents/Assets

# Optional label for the auto-seeded memory root (default: last segment of the path)
# ANSWERS_DEFAULT_MEMORY_ROOT_LABEL=abd_content

# Optional: Pinecone namespace for all memory vectors (overrides per–memory-root derived namespace).
# Folder scope in chat uses memoryFolder metadata + filters, not separate namespaces per folder.
# Prefer setting PINECONE_API_KEY, PINECONE_INDEX, PINECONE_NAMESPACE in conf/.secrets — they override
# root `.env` after server load (see applyPineconeFromConfSecrets in load-conf-openai-key.ts).
# PINECONE_NAMESPACE=memory

# First-time login (new per-user answers-store-*.json): assistant settings are copied from
# `<ANSWERS_DATA_DIR>/answers-store-jeff_anderson.json` (Jeff’s reference store). Override path:
# ANSWERS_JEFF_ASSISTANT_TEMPLATE_PATH=C:/path/to/full-answers-store.json
