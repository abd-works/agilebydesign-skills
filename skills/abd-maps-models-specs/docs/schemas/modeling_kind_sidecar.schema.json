{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agilebydesign.local/schemas/modeling_kind_sidecar.schema.json",
  "title": "modeling_kind sidecar",
  "type": "object",
  "required": ["schema_version", "kinds_distribution", "units"],
  "properties": {
    "schema_version": { "type": "string", "const": "v1" },
    "heuristic_version": { "type": "string", "description": "Classifier revision (e.g. v2 body TOC)" },
    "description": { "type": "string" },
    "kinds_distribution": {
      "type": "object",
      "additionalProperties": { "type": "integer", "minimum": 0 }
    },
    "units": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["modeling_kind", "heuristic_rule", "schema_version"],
        "properties": {
          "modeling_kind": { "type": "string" },
          "heuristic_rule": { "type": "string" },
          "schema_version": { "type": "string" },
          "heuristic_version": { "type": "string" }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
