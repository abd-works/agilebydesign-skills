{
  "schema_version": "0.2",
  "description": "Human/offline reference — NOT consumed by automated builder, orchestrator, or default evaluator. Automated scoring uses rules/mm3_domain_critic.json + corpus only.",
  "core_types": [
    "Check",
    "SkillCheck",
    "AbilityCheck",
    "AttackCheck",
    "DefenseCheck",
    "OpposedCheck",
    "ResistanceCheck",
    "Trait",
    "Skill",
    "Ability",
    "Defense",
    "Stamina",
    "Power",
    "Effect",
    "AttackEffect",
    "Damage",
    "Affliction",
    "Modifier",
    "Extra",
    "Flaw"
  ],
  "expected_relationships": [
    {"from": "Power", "to": "Effect", "kind": "contains_or_applies"},
    {"from": "SkillCheck", "to": "Skill", "kind": "uses"},
    {"from": "AbilityCheck", "to": "Ability", "kind": "uses"},
    {"from": "AttackCheck", "to": "Defense", "kind": "opposes"},
    {"from": "Damage", "to": "AttackEffect", "kind": "specializes"},
    {"from": "Affliction", "to": "AttackEffect", "kind": "specializes"},
    {"from": "ResistanceCheck", "to": "Affliction", "kind": "resists"},
    {"from": "Modifier", "to": "Effect", "kind": "may_attach"}
  ],
  "anti_patterns": [
    "Power extends Effect",
    "TOC section title promoted to class without promotion gate"
  ]
}
