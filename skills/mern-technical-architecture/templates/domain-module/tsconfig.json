{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM"],
    "strict": false,
    "jsx": "react-jsx",
    "rootDir": ".",
    "paths": {
      "@appName/domainName-shared": ["./shared/index.ts"]
    },
    "skipLibCheck": true,
    "noEmit": true,
    "ignoreDeprecations": "6.0"
  },
  "include": [
    "_lib/**/*.d.ts",
    "shared/**/*.ts",
    "server/**/*.ts",
    "client/**/*.ts",
    "client/**/*.tsx"
  ]
}
