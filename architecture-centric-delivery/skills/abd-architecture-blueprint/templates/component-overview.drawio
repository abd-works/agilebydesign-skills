        </mxCell>
        <mxCell id="mech2" value="Error Handling &amp; Resilience&#10;&#10;Result&lt;T, DomainError&gt;;&#10;retry + circuit breaker on&#10;external calls" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
