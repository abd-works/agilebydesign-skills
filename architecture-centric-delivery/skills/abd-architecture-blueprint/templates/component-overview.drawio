        <mxCell id="mech7" value="Communication&#10;&#10;Sync HTTP for queries;&#10;async events via message bus;&#10;API versioning by URL prefix" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
