        <mxCell id="mech1" value="Security&#10;&#10;Auth0 + JWT validation;&#10;role claims on token;&#10;Principal injected per request" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
