        </mxCell>
        <mxCell id="mech3" value="Logging &amp; Observability&#10;&#10;Pino structured JSON;&#10;W3C traceparent;&#10;OpenTelemetry → CloudWatch" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="520" y="470" width="200" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="mech4" value="Validation&#10;&#10;Zod schemas at API edge;&#10;business rules return&#10;Result failures" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="740" y="470" width="200" height="120" as="geometry"/>
        </mxCell>
        <mxCell id="mech5" value="Configuration&#10;&#10;Loaded once at startup;&#10;Secrets Manager;&#10;no process.env elsewhere" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
          <mxGeometry x="960" y="470" width="200" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="mech6" value="Caching&#10;&#10;Redis write-through;&#10;invalidation per admin write" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=10;align=left;verticalAlign=top;spacingLeft=8;spacingTop=8;" vertex="1" parent="1">
